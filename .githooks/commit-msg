#!/bin/sh
# commit-msg hook: enforce a DCO Signed-off-by trailer.
# Enable with: git config core.hooksPath .githooks

MSG_FILE="$1"

if ! grep -qE '^Signed-off-by: .+ <.+>$' "$MSG_FILE"; then
    echo "Error: commit message is missing a DCO 'Signed-off-by' trailer." >&2
    echo "Use 'git commit -s' (or add the trailer manually). See CONTRIBUTING.md." >&2
    exit 1
fi
